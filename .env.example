# Copy to .env for local development. Never commit .env.
APP_ENV=local

# Postgres
POSTGRES_USER=mnema
POSTGRES_PASSWORD=mnema
POSTGRES_DB=mnema
POSTGRES_PORT=5432
DATABASE_URL=postgres://mnema:mnema@localhost:5432/mnema?sslmode=disable

# MinIO (S3-compatible)
MINIO_ROOT_USER=mnema
MINIO_ROOT_PASSWORD=mnemamnema
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_BUCKET=mnema-media
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=mnema
S3_SECRET_KEY=mnemamnema
S3_BUCKET=mnema-media
S3_USE_PATH_STYLE=true

# Mailpit (SMTP capture)
MAILPIT_SMTP_PORT=1025
MAILPIT_WEB_PORT=8025
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_FROM=noreply@mnema.local

# JWT
JWT_SECRET=change-me-locally
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=720h

# LLM (leave empty in local to use stub provider)
LLM_PROVIDER=stub
OPENAI_API_KEY=
LLM_EXTRACTION_MODEL=gpt-4o-mini
LLM_EMBEDDING_MODEL=text-embedding-3-small

# Server
HTTP_PORT=8080
LOG_LEVEL=debug
APP_BASE_URL=http://localhost:5173
