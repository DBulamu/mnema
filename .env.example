# Copy to .env for local development. Never commit .env.
#
# Two kinds of variables live here:
#
#   1. Infrastructure (POSTGRES_*, MINIO_*, MAILPIT_*) — read by
#      docker-compose.yml when starting the local stack. Application
#      config (database URL, S3 credentials, etc.) is NOT pulled from
#      these — Go reads its own YAML at backend/internal/config/files/.
#
#   2. Application secrets (OPENAI_API_KEY, JWT_SECRET in test/prod) —
#      referenced inside YAML configs as ${VAR} and expanded at startup
#      via os.ExpandEnv. Local YAML hard-codes safe defaults so an
#      empty .env still works for local dev.
#
# Selects which YAML file gets loaded.
APP_ENV=local

# --- Infrastructure (docker-compose) ----------------------------------
POSTGRES_USER=mnema
POSTGRES_PASSWORD=mnema
POSTGRES_DB=mnema
POSTGRES_PORT=5432

MINIO_ROOT_USER=mnema
MINIO_ROOT_PASSWORD=mnemamnema
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_BUCKET=mnema-media

MAILPIT_SMTP_PORT=1025
MAILPIT_WEB_PORT=8025

# --- Application secrets (consumed by YAML via ${VAR}) ----------------
# Local YAML defaults to provider=stub and ignores this. Set to a real
# key + flip provider to "openai" in local.yaml to use the real model.
OPENAI_API_KEY=

# Required only when APP_ENV=test or APP_ENV=prod (the YAML for those
# envs reads ${DATABASE_URL} / ${JWT_SECRET}). Local YAML hard-codes
# them, so leaving these empty is fine for `make up && go run`.
DATABASE_URL=
JWT_SECRET=
